# Copy this file to .env, fill only the values you need, and keep .env local.
# Export the file before running Python; the project deliberately has no dotenv dependency.

# W&B reads this credential directly. Prefer `wandb login` when possible.
# WANDB_API_KEY=replace-with-a-local-key-and-never-commit-it
WANDB_ENTITY=
WANDB_PROJECT=world-gan

# Developer-specific data and output locations.
CONWORLDGAN_INPUT_WORLDS_DIR=
CONWORLDGAN_OUTPUT_WORLDS_DIR=
CONWORLDGAN_REPR_DIR=
CONWORLDGAN_RUNS_DIR=

# Optional Mineways rendering tools.
CONWORLDGAN_WINE_BIN=
CONWORLDGAN_MINEWAYS_BIN=
CONWORLDGAN_MINEWAYS_SCRIPT_DIR=
